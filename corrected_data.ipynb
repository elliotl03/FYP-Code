    "# --- FOLLOW-ON CELL: supports shared AND per-curve normalization modes ---\n",
    "\n",
    "import re, numpy as np, matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "# ===== EDIT THESE =====\n",
    "CALIBRATION_FILE = Path(\"/Users/Elliot/Library/CloudStorage/OneDrive-DublinCityUniversity/vscode/Calibration_Factor.rtf\")\n",
    "CALIB_IS_FACTOR  = True  # True: multiply factor; False: divide response\n",
    "NORMALIZE_MODE   = \"per_curve_max\"  # \"per_curve_max\"|\"area\"|\"l2\"|\"minmax\"|\n",
    "                                   # \"shared_max\"|\"raw_max\"|\"cal_max\"|\"line_anchor\"\n",
    "ANCHOR_WL_NM     = 656.3           # for \"line_anchor\"\n",
    "ANCHOR_WINDOW_NM = 0.6\n",
    "# ======================\n",
    "\n",
    "_NUM = r\"[+-]?(?:\\d+(?:\\.\\d+)?|\\.\\d+)(?:[eE][+-]?\\d+)?\"\n",
    "\n",
    "def read_text(path: Path) -> str:\n",
    "    return path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n",
    "\n",
    "def detect_decimal_and_delimiter(lines):\n",
    "    sample = \"\\n\".join(lines[:200])\n",
    "    dec_comma = bool(re.search(r\"\\d+,\\d+\", sample)) and not bool(re.search(r\"\\d+\\.\\d+\", sample))\n",
    "    if any(\"\\t\" in ln for ln in lines[:50]):   delim = \"\\t\"\n",
    "    elif any(\";\" in ln for ln in lines[:50]):  delim = \";\"\n",
    "    elif any(\",\" in ln for ln in lines[:50]):  delim = \",\"\n",
    "    else: delim = None\n",
    "    return dec_comma, delim\n",
    "\n",
    "def parse_numeric_block(text: str):\n",
    "    lines = [ln.strip() for ln in text.splitlines() if ln.strip()]\n",
    "    if not lines: raise ValueError(\"Empty file\")\n",
    "    dec_comma, delim = detect_decimal_and_delimiter(lines)\n",
    "    if dec_comma:\n",
    "        def fix_decimals(s): return re.sub(r\"(?<=\\d),(?=\\d)\", \".\", s)\n",
    "        lines = [fix_decimals(ln) for ln in lines]\n",
    "    rows = []\n",
    "    for ln in lines:\n",
    "        parts = re.split(rf\"{re.escape(delim)}|\\s+\" if delim else r\"\\s+\", ln)\n",
    "        toks = [p for p in parts if re.fullmatch(_NUM, p)]\n",
    "        if 2 <= len(toks) <= 4:\n",
    "            try: rows.append([float(t) for t in toks])\n",
    "            except Exception: rows.append(None)\n",
    "        else:\n",
    "            rows.append(None)\n",
    "    best_s, best_e, s = -1, -1, None\n",
    "    for i, r in enumerate(rows):\n",
    "        if r is not None and s is None: s = i\n",
    "        end = (r is None) or (i == len(rows)-1)\n",
    "        if end and s is not None:\n",
    "            e = i if r is not None else i-1\n",
    "            if (e - s) > (best_e - best_s): best_s, best_e = s, e\n",
    "            s = None\n",
    "    if best_s < 0: raise ValueError(\"No numeric block found.\")\n",
    "    block = [rows[i] for i in range(best_s, best_e+1) if rows[i] is not None]\n",
    "    arr = np.array([r[:3] for r in block], dtype=float)\n",
    "    if arr.shape[1] < 2: raise ValueError(\"Found numbers but fewer than 2 numeric columns.\")\n",
    "    wl, raw = arr[:,0], arr[:,1]\n",
    "    dark = arr[:,2] if arr.shape[1] >= 3 else np.zeros_like(raw)\n",
    "    return wl, raw, dark\n",
    "\n",
    "def load_calibration_table(path: Path):\n",
    "    wl, fac, _ = parse_numeric_block(read_text(path))\n",
    "    order = np.argsort(wl)\n",
    "    return wl[order], fac[order]\n",
    "\n",
    "def interp_factor(target_wl, calib_wl, calib_fac):\n",
    "    return np.interp(target_wl, calib_wl, calib_fac, left=calib_fac[0], right=calib_fac[-1])\n",
    "\n",
    "def pick_file():\n",
    "    try:\n",
    "        import tkinter as tk\n",
    "        from tkinter import filedialog\n",
    "        root = tk.Tk(); root.withdraw()\n",
    "        fname = filedialog.askopenfilename(\n",
    "            title=\"Select a raw spectrum file\",\n",
    "            filetypes=[(\"Data files\",\"*.csv *.tsv *.txt *.dat *.rtf\"), (\"All files\",\"*.*\")]\n",
    "        )\n",
    "        root.update(); root.destroy()\n",
    "        return Path(fname) if fname else None\n",
    "    except Exception:\n",
    "        p = input(\"Enter path to raw spectrum file: \").strip()\n",
    "        return Path(p) if p else None\n",
    "\n",
    "def peak_in_window(y, wl, anchor, halfwin):\n",
    "    m = (wl >= anchor-halfwin) & (wl <= anchor+halfwin)\n",
    "    return np.nanmax(np.abs(y[m])) if np.any(m) else np.nan\n",
    "\n",
    "def normalize_per_curve(y, wl, mode):\n",
    "    m = mode.lower()\n",
    "    if m == \"per_curve_max\":\n",
    "        s = np.nanmax(np.abs(y)); return (y/s if s>0 else y), s, \"per-curve max\"\n",
    "    if m == \"area\":\n",
    "        area = np.trapz(np.clip(y,0,None), wl); return (y/area if area>0 else y), area, \"per-curve area\"\n",
    "    if m == \"l2\":\n",
    "        l2 = np.sqrt(np.nansum(y**2)); return (y/l2 if l2>0 else y), l2, \"per-curve l2\"\n",
    "    if m == \"minmax\":\n",
    "        mn, mx = np.nanmin(y), np.nanmax(y); rng = mx-mn\n",
    "        return ((y-mn)/rng if rng>0 else y), (rng if rng>0 else 1.0), \"per-curve minmax\"\n",
    "    raise ValueError(f\"Unknown per-curve mode: {mode}\")\n",
    "\n",
    "def compute_shared_scale(raw, cal, wl, mode):\n",
    "    m = mode.lower()\n",
    "    if m == \"shared_max\":\n",
    "        return max(np.nanmax(np.abs(raw)), np.nanmax(np.abs(cal))), \"shared max\"\n",
    "    if m == \"raw_max\":\n",
    "        return np.nanmax(np.abs(raw)), \"raw max\"\n",
    "    if m == \"cal_max\":\n",
    "        return np.nanmax(np.abs(cal)), \"cal max\"\n",
    "    if m == \"line_anchor\":\n",
    "        pr = peak_in_window(raw, wl, ANCHOR_WL_NM, ANCHOR_WINDOW_NM)\n",
    "        pc = peak_in_window(cal, wl, ANCHOR_WL_NM, ANCHOR_WINDOW_NM)\n",
    "        return max(pr, pc), f\"anchor {ANCHOR_WL_NM}±{ANCHOR_WINDOW_NM} nm\"\n",
    "    raise ValueError(f\"Unknown shared mode: {mode}\")\n",
    "\n",
    "# --- run ---\n",
    "calib_wl, calib_fac = load_calibration_table(CALIBRATION_FILE)\n",
    "print(f\"[info] Calibration loaded: {len(calib_wl)} points from {CALIBRATION_FILE.name}\")\n",
    "\n",
    "raw_path = pick_file()\n",
    "if not raw_path:\n",
    "    print(\"[cancelled] No file selected.\")\n",
    "else:\n",
    "    wl, raw, dark = parse_numeric_block(read_text(raw_path))\n",
    "    fac = interp_factor(wl, calib_wl, calib_fac)\n",
    "    calibrated = (raw - dark) * fac if CALIB_IS_FACTOR else (raw - dark) / np.maximum(fac, 1e-12)\n",
    "\n",
    "    mode = NORMALIZE_MODE.lower()\n",
    "    if mode in (\"per_curve_max\",\"area\",\"l2\",\"minmax\"):\n",
    "        raw_n, s1, tag1 = normalize_per_curve(raw, wl, mode)\n",
    "        cal_n, s2, tag2 = normalize_per_curve(calibrated, wl, mode)\n",
    "        desc = f\"{tag1} / {tag2}\"\n",
    "        # Plot RAW\n",
    "        plt.figure(figsize=(9,5), dpi=140)\n",
    "        plt.plot(wl, raw_n, color=\"#7f7f7f\", lw=1.1, label=f\"Raw ({tag1})\")\n",
    "        if np.any(dark):\n",
    "            d_n, _, _ = normalize_per_curve(dark, wl, mode)\n",
    "            plt.plot(wl, d_n, color=\"#bdbdbd\", lw=0.9, label=\"Dark (per-curve)\")\n",
    "        plt.ylim(0,1) if mode in (\"per_curve_max\",\"minmax\") else None\n",
    "        plt.xlabel(\"Wavelength (nm)\"); plt.ylabel(\"Normalized intensity\")\n",
    "        plt.title(f\"RAW — {raw_path.name}  [{desc}]\")\n",
    "        plt.grid(alpha=0.25, ls=\"--\"); plt.legend(frameon=False); plt.tight_layout(); plt.show()\n",
    "        # Plot CAL\n",
    "        plt.figure(figsize=(9,5), dpi=140)\n",
    "        plt.plot(wl, cal_n, color=\"#1f77b4\", lw=1.1, label=f\"Calibrated ({tag2})\")\n",
    "        plt.ylim(0,1) if mode in (\"per_curve_max\",\"minmax\") else None\n",
    "        plt.xlabel(\"Wavelength (nm)\"); plt.ylabel(\"Normalized intensity\")\n",
    "        plt.title(f\"CALIBRATED — {raw_path.name}  [{desc}]\")\n",
    "        plt.grid(alpha=0.25, ls=\"--\"); plt.legend(frameon=False); plt.tight_layout(); plt.show()\n",
    "    else:\n",
    "        # shared modes\n",
    "        scale, tag = compute_shared_scale(raw, calibrated, wl, mode)\n",
    "        if not np.isfinite(scale) or scale <= 0: scale = 1.0\n",
    "        raw_n = raw / scale\n",
    "        cal_n = calibrated / scale\n",
    "        dark_n = dark / scale if np.any(dark) else dark\n",
    "        # Plot RAW\n",
    "        plt.figure(figsize=(9,5), dpi=140)\n",
    "        plt.plot(wl, raw_n, color=\"#7f7f7f\", lw=1.1, label=f\"Raw (shared: {tag})\")\n",
    "        if np.any(dark): plt.plot(wl, dark_n, color=\"#bdbdbd\", lw=0.9, label=\"Dark (shared)\")\n",
    "        plt.ylim(0,1); plt.xlabel(\"Wavelength (nm)\"); plt.ylabel(\"Normalized intensity (0–1)\")\n",
    "        plt.title(f\"RAW — {raw_path.name}  [shared scaling: {tag}]\")\n",
    "        plt.grid(alpha=0.25, ls=\"--\"); plt.legend(frameon=False); plt.tight_layout(); plt.show()\n",
    "        # Plot CAL\n",
    "        plt.figure(figsize=(9,5), dpi=140)\n",
    "        plt.plot(wl, cal_n, color=\"#1f77b4\", lw=1.1, label=f\"Calibrated (shared: {tag})\")\n",
    "        plt.ylim(0,1); plt.xlabel(\"Wavelength (nm)\"); plt.ylabel(\"Normalized intensity (0–1)\")\n",
    "        plt.title(f\"CALIBRATED — {raw_path.name}  [shared scaling: {tag}]\")\n",
    "        plt.grid(alpha=0.25, ls=\"--\"); plt.legend(frameon=False); plt.tight_layout(); plt.show()\n",
    "\n",
    "    print(f\"[ok] Mode used: {NORMALIZE_MODE}\")\n"
   ]
  }
